{
  "types": {
    "dynatrace.datasource.python:myipcrossextension-endpoint": {
      "type": "object",
      "displayName": "Ping Target Endpoint",
      "summaryPattern": "Ping target {host} ({alias})",
      "properties": {
        "host": {
          "displayName": "Host / IP Address",
          "type": "text",
          "nullable": false,
          "default": "",
          "constraints": [
            {
              "type": "LENGTH",
              "minLength": 1,
              "maxLength": 255
            }
          ],
          "maxItems": 1
        },
        "alias": {
          "displayName": "Alias / Friendly Name",
          "type": "text",
          "nullable": true,
          "default": "",
          "constraints": [
            {
              "type": "LENGTH",
              "minLength": 0,
              "maxLength": 100
            }
          ],
          "maxItems": 1
        },
        "packets": {
          "displayName": "Packets Count",
          "type": "integer",
          "nullable": true,
          "default": 4,
          "constraints": [
            {
              "type": "RANGE",
              "minimum": 1,
              "maximum": 20
            }
          ],
          "maxItems": 1
        },
        "timeout": {
          "displayName": "Timeout (seconds)",
          "type": "integer",
          "nullable": true,
          "default": 2,
          "constraints": [
            {
              "type": "RANGE",
              "minimum": 1,
              "maximum": 10
            }
          ],
          "maxItems": 1
        }
      }
    },
    "pythonRemote": {
      "type": "object",
      "properties": {
        "endpoints": {
          "displayName": "Myipcrossextension endpoint",
          "type": "list",
          "items": {
            "type": {
              "$ref": "#/types/dynatrace.datasource.python:myipcrossextension-endpoint"
            }
          },
          "nullable": false,
          "minItems": 1,
          "maxItems": 100,
          "metaData": {
            "addItemButton": "Add endpoint"
          }
        }
      }
    },
    "pythonLocal": {
      "type": "object",
      "properties": {
        "endpoints": {
          "displayName": "Myipcrossextension endpoint",
          "type": "list",
          "items": {
            "type": {
              "$ref": "#/types/dynatrace.datasource.python:myipcrossextension-endpoint"
            }
          },
          "nullable": false,
          "minItems": 1,
          "maxItems": 100,
          "metaData": {
            "addItemButton": "Add endpoint"
          }
        }
      }
    }
  },
  "dynatrace": "1",
  "description": "myipcrossextension configuration",
  "schemaId": "python-extension.activation",
  "displayName": "myipcrossextension configuration",
  "ownerProductManagement": "dynatrace",
  "ownerDevelopment": "dynatrace",
  "maturity": "GENERAL_AVAILABILITY",
  "allowedScopes": [
    "tenant"
  ],
  "multiObject": false,
  "properties": {
    "pythonLocal": {
      "displayName": "Python Local Extension",
      "type": {
        "$ref": "#/types/pythonLocal"
      }
    },
    "pythonRemote": {
      "displayName": "Python Remote Extension",
      "type": {
        "$ref": "#/types/pythonRemote"
      }
    }
  }
}
