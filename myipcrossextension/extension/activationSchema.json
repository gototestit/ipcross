{
  "types": {
    "dynatrace.datasource.python:myipcrossextension-endpoint": {
      "type": "object",
      "displayName": "Network Target Endpoint",
      "summaryPattern": "Target {host} ({alias})",
      "properties": {
        "host": {
          "displayName": "Host / IP Address / Domain",
          "type": "text",
          "nullable": false,
          "default": "",
          "constraints": [
            {
              "type": "LENGTH",
              "minLength": 1,
              "maxLength": 255
            }
          ],
          "maxItems": 1
        },
        "alias": {
          "displayName": "Alias / Friendly Name",
          "type": "text",
          "nullable": true,
          "constraints": [
            {
              "type": "LENGTH",
              "minLength": 0,
              "maxLength": 100
            }
          ],
          "maxItems": 1
        },
        "enable_icmp": {
          "displayName": "Enable Ping (ICMP)",
          "type": "boolean",
          "nullable": false,
          "default": true,
          "maxItems": 1
        },
        "enable_tcp": {
          "displayName": "Enable TCP Socket Connect",
          "type": "boolean",
          "nullable": false,
          "default": false,
          "maxItems": 1
        },
        "enable_dns": {
          "displayName": "Enable DNS Name Resolution",
          "type": "boolean",
          "nullable": false,
          "default": false,
          "maxItems": 1
        },
        "enable_http": {
          "displayName": "Enable HTTP Service Verification",
          "type": "boolean",
          "nullable": false,
          "default": false,
          "maxItems": 1
        },
        "port": {
          "displayName": "Port (required for TCP/HTTP)",
          "type": "integer",
          "nullable": true,
          "constraints": [
            {
              "type": "RANGE",
              "minimum": 1,
              "maximum": 65535
            }
          ],
          "maxItems": 1
        },
        "packets": {
          "displayName": "Packets/Tries Count",
          "type": "integer",
          "nullable": true,
          "constraints": [
            {
              "type": "RANGE",
              "minimum": 1,
              "maximum": 20
            }
          ],
          "maxItems": 1
        },
        "timeout": {
          "displayName": "Timeout (seconds)",
          "type": "integer",
          "nullable": true,
          "constraints": [
            {
              "type": "RANGE",
              "minimum": 1,
              "maximum": 10
            }
          ],
          "maxItems": 1
        }
      }
    },
    "pythonRemote": {
      "type": "object",
      "properties": {
        "endpoints": {
          "displayName": "Myipcrossextension endpoint",
          "type": "list",
          "items": {
            "type": {
              "$ref": "#/types/dynatrace.datasource.python:myipcrossextension-endpoint"
            }
          },
          "nullable": false,
          "minItems": 1,
          "maxItems": 100,
          "metaData": {
            "addItemButton": "Add endpoint"
          }
        }
      }
    },
    "pythonLocal": {
      "type": "object",
      "properties": {
        "endpoints": {
          "displayName": "Myipcrossextension endpoint",
          "type": "list",
          "items": {
            "type": {
              "$ref": "#/types/dynatrace.datasource.python:myipcrossextension-endpoint"
            }
          },
          "nullable": false,
          "minItems": 1,
          "maxItems": 100,
          "metaData": {
            "addItemButton": "Add endpoint"
          }
        }
      }
    }
  },
  "dynatrace": "1",
  "description": "myipcrossextension configuration",
  "schemaId": "python-extension.activation",
  "displayName": "myipcrossextension configuration",
  "ownerProductManagement": "dynatrace",
  "ownerDevelopment": "dynatrace",
  "maturity": "GENERAL_AVAILABILITY",
  "allowedScopes": [
    "tenant"
  ],
  "multiObject": false,
  "properties": {
    "pythonLocal": {
      "displayName": "Python Local Extension",
      "type": {
        "$ref": "#/types/pythonLocal"
      }
    },
    "pythonRemote": {
      "displayName": "Python Remote Extension",
      "type": {
        "$ref": "#/types/pythonRemote"
      }
    }
  }
}
